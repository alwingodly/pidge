generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Platform content ─────────────────────────────────────────────────────────
model PlatformLoginContent {
  id             String   @id @default("default")
  eyebrow        String   @default("SaaS operating console")
  headline       String   @default("Serious operations, surprisingly human.")
  description    String   @default("A calm command center for tenant growth, clinic workflows, bookings, and access control.")
  panelLabel     String   @default("Today")
  statusLabel    String   @default("Healthy")
  metricOneLabel String   @default("Tenants")
  metricOneValue String   @default("28")
  metricTwoLabel String   @default("Bookings")
  metricTwoValue String   @default("846")
  metricThreeLabel String @default("Pending")
  metricThreeValue String @default("12")
  footerNote     String   @default("Protected console access for super admins and clinic teams.")
  updatedAt      DateTime @updatedAt
}

// ── Tenant ────────────────────────────────────────────────────────────────────
model Tenant {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  businessType   String   @default("CLINIC")
  country        String   @default("GB")
  timezone       String   @default("Europe/London")
  locale         String   @default("en-GB")
  currency       String   @default("GBP")
  currencySymbol String   @default("£")
  logoUrl        String?
  primaryColor   String   @default("#4996D7")
  landingHeadline      String? @db.Text
  landingSubheadline   String? @db.Text
  landingPrimaryCta    String?
  landingSecondaryCta  String?
  landingTrustBadges   String? @db.Text
  landingBottomHeadline String? @db.Text
  landingBottomText     String? @db.Text
  plan             String   @default("FREE")
  stripeAccountId  String?  // Stripe Connect acct_xxx — set after clinic connects their account
  stripeOnboarded  Boolean  @default(false) // true once clinic completes Stripe onboarding
  clinicStartTime  String?  // "09:00" — opening time shown on booking page
  clinicEndTime    String?  // "17:00" — closing time
  reviewLink           String?  // e.g. Google Maps review URL — sent to patients after COMPLETED
  reminderEnabled      Boolean  @default(true)   // send appointment reminders to patients
  reminderHoursBefore  Int      @default(24)      // how many hours before to send the reminder
  bookingAlertsEnabled      Boolean  @default(true)  // send admin email when a new booking arrives
  assignmentEmailEnabled    Boolean  @default(true)  // send patient email when appointment is approved
  rescheduleEmailEnabled    Boolean  @default(true)  // send patient email when appointment is rescheduled
  notificationEmail    String?  // override recipient for booking alerts; defaults to tenant admin email
  manualBookingEnabled    Boolean @default(false)
  recurrenceEnabled       Boolean @default(false)
  gdprEnabled             Boolean @default(false) // UK GDPR mode: consent checkbox, opt-out, erasure
  waitlistEnabled         Boolean @default(false) // allow patients to join a waitlist
  patientHistoryEnabled Boolean @default(true)
  onlinePaymentsEnabled Boolean @default(false) // when false, Stripe step is skipped — offline/cash only
  walkInEnabled Boolean @default(true)
  branchModeEnabled Boolean @default(false)
  isActive            Boolean  @default(true)
  showDoctorSelection Boolean  @default(false) // super-admin feature flag
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branches     Branch[]
  adminUsers   AdminUser[]
  doctors      Doctor[]
  services     Service[]
  slots        Slot[]
  appointments Appointment[]
  appointmentStatusHistory AppointmentStatusHistory[]
  auditLogs    AuditLog[]
  workingHours   WorkingHours[]
  doctorLeaves   DoctorLeave[]
  serviceConfigs ServiceBranchConfig[]
  waitlist       Waitlist[]
}

// ── Branch ────────────────────────────────────────────────────────────────────
model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  address   String?
  phone     String?
  timezone  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  adminUsers   AdminUser[]
  doctors      Doctor[]
  slots        Slot[]
  appointments   Appointment[]
  serviceConfigs ServiceBranchConfig[]
  waitlist       Waitlist[]

  @@unique([tenantId, slug])
}

// ── AdminUser ─────────────────────────────────────────────────────────────────
model AdminUser {
  id            String    @id @default(uuid())
  tenantId      String
  branchId      String?
  name          String
  email         String    @unique
  password      String
  role          String
  isActive      Boolean   @default(true)
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])
}

// ── Doctor ────────────────────────────────────────────────────────────────────
model Doctor {
  id               String   @id @default(uuid())
  tenantId         String
  branchId         String?
  name             String
  practitionerType String   @default("VAIDYA")
  speciality       String
  bio              String?
  photoUrl         String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  branch         Branch?         @relation(fields: [branchId], references: [id])
  slots          Slot[]
  appointments   Appointment[]
  doctorServices DoctorService[]
  workingHours   WorkingHours[]
  leaves         DoctorLeave[]
}

// ── Service ───────────────────────────────────────────────────────────────────
model Service {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  durationMins Int      @default(30)
  price        Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  appointments   Appointment[]
  slots          Slot[]
  doctorServices DoctorService[]
  branchConfigs  ServiceBranchConfig[]
  waitlist       Waitlist[]
}

// ── ServiceBranchConfig — per-branch availability of a service ───────────────
model ServiceBranchConfig {
  id          String  @id @default(uuid())
  tenantId    String
  serviceId   String
  branchId    String
  isOffered   Boolean @default(true)  // false = not offered here (tenant admin)
  isAvailable Boolean @default(true)  // false = temporarily unavailable (any admin)

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId],  references: [id], onDelete: Cascade)

  @@unique([serviceId, branchId])
}

// ── DoctorService — which doctor offers which services ────────────────────────
model DoctorService {
  id        String @id @default(uuid())
  doctorId  String
  serviceId String

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([doctorId, serviceId])
}

// ── Slot ──────────────────────────────────────────────────────────────────────
model Slot {
  id           String   @id @default(uuid())
  tenantId     String
  branchId     String?
  doctorId     String
  serviceId    String?
  durationMins Int      @default(30)
  date         DateTime
  startTime    String
  endTime      String
  isBooked     Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  doctor      Doctor       @relation(fields: [doctorId], references: [id])
  service     Service?     @relation(fields: [serviceId], references: [id])
  appointment Appointment?
}

// ── Appointment ───────────────────────────────────────────────────────────────
model Appointment {
  id             String    @id @default(uuid())
  tenantId       String
  branchId       String?
  slotId         String?   @unique       // null for new admin-assigned flow
  serviceId      String
  doctorId       String?                 // null until admin assigns
  bookingRef     String    @unique
  patientName      String
  patientSurname   String?
  patientEmail     String
  patientPhone     String
  patientDOB       String?                 // stored as encrypted ISO date string
  patientGender    String?
  notes            String?
  attachmentData   String?
  attachmentName   String?
  preferredDate  DateTime?               // patient's requested date
  assignedDate   DateTime?               // admin-confirmed date
  assignedTime   String?                 // admin-confirmed time "10:30"
  status          String    @default("PENDING")
  appointmentType String    @default("ONLINE")    // "ONLINE" | "WALK_IN"
  checkedInAt     DateTime?                       // wall-clock arrival time for walk-ins
  cancelToken     String    @unique
  reminderSent      Boolean   @default(false)
  reminderOptOut    Boolean   @default(false) // patient opted out of reminder emails
  consentGivenAt    DateTime?               // GDPR: timestamp of explicit data processing consent
  recurrenceGroupId String?   // shared UUID linking a recurring series
  recurrenceIndex   Int?      // 1-based position in the series
  recurrenceTotal   Int?      // total appointments in the series
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  branch  Branch?  @relation(fields: [branchId], references: [id])
  slot    Slot?    @relation(fields: [slotId],    references: [id])
  service Service  @relation(fields: [serviceId], references: [id])
  doctor  Doctor?  @relation(fields: [doctorId],  references: [id])
  statusHistory AppointmentStatusHistory[]
  auditLogs     AuditLog[]
}

// ── AppointmentStatusHistory — lightweight lifecycle timeline ────────────────
model AppointmentStatusHistory {
  id            String   @id @default(uuid())
  tenantId      String
  appointmentId String
  fromStatus    String?
  toStatus      String
  actorId       String?
  actorName     String?
  actorRole     String?
  note          String?
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, appointmentId, createdAt])
}

// ── AuditLog — internal admin/system event trail ─────────────────────────────
model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  appointmentId String?
  actorId       String?
  actorName     String?
  actorRole     String?
  action        String
  entityType    String
  entityId      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([appointmentId, createdAt])
}

// ── BookingOTP — short-lived email verification codes for patient booking ─────
model BookingOTP {
  id        String   @id @default(uuid())
  email     String
  otpHash   String   // HMAC-SHA256 of the OTP — never store raw OTP
  attempts  Int      @default(0)
  expiresAt DateTime
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
}

// ── PasswordResetToken ────────────────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── WorkingHours — per-doctor recurring weekly schedule ───────────────────────
model WorkingHours {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  doctorId  String
  dayOfWeek Int      // 0 = Sunday … 6 = Saturday
  startTime String   // "09:00"
  endTime   String   // "18:00"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  doctor Doctor  @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, dayOfWeek])
}

// ── DoctorLeave — blocks a doctor's availability for a date range ─────────────
model DoctorLeave {
  id        String   @id @default(uuid())
  tenantId  String
  doctorId  String
  startDate DateTime // inclusive
  endDate   DateTime // inclusive
  period    String   @default("FULL") // FULL | MORNING | AFTERNOON
  reason    String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId, startDate])
  @@index([tenantId, startDate])
}

// ── Waitlist — patients waiting for a slot to open for a service ─────────────
model Waitlist {
  id           String    @id @default(uuid())
  tenantId     String
  serviceId    String
  branchId     String?
  patientName  String
  patientEmail String
  patientPhone String
  preferredDate DateTime?
  leaveToken   String    @unique // sent to patient so they can remove themselves
  notifiedAt   DateTime? // set when we email them that a slot opened up
  createdAt    DateTime  @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])
  branch  Branch?  @relation(fields: [branchId],  references: [id])

  @@index([tenantId, serviceId, notifiedAt, createdAt])
}
